			<항>
				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[①원호재산이 담보물권의 설정 기타에 의하여 상환의 대상이 되어 있을 경우에는 이 법에 의하여 당해 원호재산을 증여받은 자가 그 채무를 변제하여야 한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[②제1항의 원호재산은 채무의 변제가 있은 후가 아니면 이를 증여할 수 없다. <개정 1974.12.24>]]>
				</항내용>
			</항>

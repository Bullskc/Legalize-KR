---
layout: base.njk
pagination:
  data: laws
  size: 1
  alias: law
permalink: "laws/{{ law.mst }}/index.html"
eleventyComputed:
  title: "{{ law.title }} — Legalize KR"
  description: "{{ law.title }} 전문. {{ law.lawType }}, 소관부처: {{ law.ministry | join(', ') }}, 공포일자: {{ law.promulgatedAt }}"
---

<main class="law-detail-page">
  <div class="law-detail-container">

    <a href="/laws/" class="back-link">← 법령 목록</a>

    <div class="law-detail-header">
      <div class="law-detail-title-row">
        <h1>{{ law.title }}</h1>
        <span class="law-type-badge law-type-{{ law.lawType | replace(' ', '') }}">{{ law.lawType }}</span>
      </div>
      <div class="law-detail-meta">
        {% if law.ministry.length %}
        <span>
          <span class="meta-label">소관부처</span>
          {{ law.ministry | join(", ") }}
        </span>
        {% endif %}
        {% if law.promulgatedAt %}
        <span>
          <span class="meta-label">공포일자</span>
          {{ law.promulgatedAt }}
        </span>
        {% endif %}
        {% if law.enforcedAt %}
        <span>
          <span class="meta-label">시행일자</span>
          {{ law.enforcedAt }}
        </span>
        {% endif %}
        {% if law.status %}
        <span class="law-status-badge">{{ law.status }}</span>
        {% endif %}
      </div>
      <div class="law-detail-links">
        <a href="{{ law.githubUrl }}" target="_blank" rel="noopener" class="law-ext-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub에서 보기
        </a>
        <a href="https://www.law.go.kr/법령/{{ law.dirName }}" target="_blank" rel="noopener" class="law-ext-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          국가법령정보센터
        </a>
      </div>
    </div>

    <div class="law-body">
      {{ law.absPath | readLawFile | safe }}
    </div>

  </div>
</main>
